<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        AxF GymNet — Tema base unificado
        Usa la paleta oscura (#070E1A) como fondo global.
        El color primario es el naranja #F26A21.
    -->
    <style name="Base.Theme.AxFGymNet" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/axf_bg_deep</item>
        <item name="colorPrimary">@color/axf_orange</item>
        <item name="colorOnPrimary">@color/axf_text_primary</item>
        <item name="colorSurface">@color/axf_bg_card</item>
        <item name="colorOnSurface">@color/axf_text_primary</item>
        <item name="android:textColorPrimary">@color/axf_text_primary</item>
        <item name="android:textColorSecondary">@color/axf_text_secondary</item>
        <!-- Edge-to-edge: barras transparentes para Android 15 -->
        <!-- Los WindowInsets en el código se encargan del padding real -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        
        <!-- Fix para AlertDialogs -->
        <item name="alertDialogTheme">@style/AxFAlertDialog</item>
        <item name="materialAlertDialogTheme">@style/AxFAlertDialog</item>
    </style>

    <style name="Theme.AxFGymNet" parent="Base.Theme.AxFGymNet" />

    <style name="AxFAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <!-- Force dark background and white text for dialogs -->
        <item name="colorSurface">@color/axf_bg_card</item>
        <item name="colorOnSurface">@color/axf_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/axf_text_secondary</item>
        <item name="colorPrimary">@color/axf_orange</item>
        <!-- For older AppCompat dialogs -->
        <item name="android:textColorPrimary">@color/axf_text_primary</item>
    </style>

    <!-- Dialog de descanso -->
    <style name="DialogDescanso" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.75</item>
    </style>
</resources>

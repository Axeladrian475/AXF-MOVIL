<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_descanso.xml — Diálogo de descanso entre series
    ANTES: progressTint #007AFF (azul iOS)
    AHORA: axf_orange — paleta unificada
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="288dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/axf_bg_card"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descanso"
        android:textColor="@color/axf_text_secondary"
        android:textSize="13sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <!-- Cuenta atrás grande -->
    <TextView
        android:id="@+id/tvCuentaAtras"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2:00"
        android:textColor="@color/axf_text_primary"
        android:textSize="64sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Barra de progreso -->
    <ProgressBar
        android:id="@+id/progressDescanso"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:progressTint="@color/axf_orange"
        android:progressBackgroundTint="@color/axf_bg_surface"
        android:layout_marginBottom="24dp"/>

    <!-- Botón saltar -->
    <Button
        android:id="@+id/btnSaltarDescanso"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Saltar"
        android:backgroundTint="@color/axf_bg_surface"
        android:textColor="@color/axf_text_secondary"
        android:textSize="15sp"
        android:stateListAnimator="@null"/>

</LinearLayout>

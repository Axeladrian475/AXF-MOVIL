<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/axf_bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/axf_bg_primary"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvPagoBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← "
            android:textColor="@color/axf_orange"
            android:textSize="20sp"
            android:paddingEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pagar con tarjeta"
                android:textColor="@color/axf_text_primary"
                android:textSize="18sp"
                android:fontFamily="@font/jockey_one"/>

            <TextView
                android:id="@+id/tvPagoPlan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_text_secondary"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pbPago"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/axf_orange"/>

    <WebView
        android:id="@+id/webPayPal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/axf_bg_deep">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/axf_bg_primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnVolverReportar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Volver"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reportes"
            android:textColor="@color/axf_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- ── TABS ── -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutReportes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/axf_bg_primary"
        app:tabTextColor="@color/axf_text_secondary"
        app:tabSelectedTextColor="@color/axf_orange"
        app:tabIndicatorColor="@color/axf_orange"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nuevo"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Públicos"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mis Reportes"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- ══ TAB 0: NUEVO REPORTE ══ -->
    <LinearLayout
        android:id="@+id/layoutNuevoReporte"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Sucursal -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sucursal donde ocurrió el problema"
                    android:textColor="@color/axf_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="6dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="14dp">
                    <Spinner
                        android:id="@+id/spinnerSucursal"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@null"/>
                </androidx.cardview.widget.CardView>

                <!-- Categoría -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Categoría"
                    android:textColor="@color/axf_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="6dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="14dp">
                    <Spinner
                        android:id="@+id/spinnerCategoria"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@null"/>
                </androidx.cardview.widget.CardView>

                <!-- Personal (solo Reporte de Personal) -->
                <LinearLayout
                    android:id="@+id/layoutPersonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Personal a reportar"
                        android:textColor="@color/axf_text_secondary"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="6dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/axf_bg_card"
                        android:layout_marginBottom="14dp">
                        <Spinner
                            android:id="@+id/spinnerPersonal"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@null"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Aviso atención previa -->
                    <LinearLayout
                        android:id="@+id/layoutAtencionPrevia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/axf_orange_tint"
                        android:padding="12dp"
                        android:layout_marginBottom="14dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Este personal te brindó atención previamente."
                            android:textColor="@color/axf_orange"
                            android:textSize="12sp"
                            android:layout_marginBottom="8dp"/>

                        <CheckBox
                            android:id="@+id/cbSobreAtencion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mi reporte es sobre esa atención que me brindó"
                            android:textColor="@color/axf_text_primary"
                            android:textSize="13sp"
                            android:buttonTint="@color/axf_orange"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Descripción -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descripción del problema"
                    android:textColor="@color/axf_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="4"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:hint="Describe el problema con detalle..."
                        android:textColor="@color/axf_text_primary"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- FOTO (NUEVO) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Evidencia (Opcional)"
                    android:textColor="@color/axf_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSeleccionarFoto"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/axf_bg_card"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivFotoPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_fire"
                            android:padding="20dp"
                            android:scaleType="centerInside"
                            android:alpha="0.5"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvFotoStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toca para subir una foto"
                        android:textColor="@color/axf_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <!-- Privado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <CheckBox
                        android:id="@+id/cbPrivado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/axf_orange"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_lock"
                        android:contentDescription="Privado"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hacer reporte privado (solo visible al personal)"
                        android:textColor="@color/axf_text_secondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Botón enviar -->
                <Button
                    android:id="@+id/btnEnviarReporte"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Enviar Reporte"
                    android:textColor="@color/axf_text_primary"
                    android:backgroundTint="@color/axf_orange"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="8dp"
                    android:stateListAnimator="@null"/>

                <TextView
                    android:id="@+id/tvEstadoEnvio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- ══ TAB 1: REPORTES PÚBLICOS ══ -->
    <LinearLayout
        android:id="@+id/layoutReportesPublicos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:background="@color/axf_bg_card"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ver reportes de:"
                android:textColor="@color/axf_text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerSucursalPublicos"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/axf_bg_surface"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pbPublicos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:indeterminateTint="@color/axf_orange"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvSinReportes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No hay reportes activos en esta sucursal"
            android:textColor="@color/axf_text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReportesPublicos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- ══ TAB 2: MIS REPORTES ══ -->
    <LinearLayout
        android:id="@+id/layoutMisReportes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/pbMisReportes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:indeterminateTint="@color/axf_orange"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvSinMisReportes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aún no has enviado ningún reporte."
            android:textColor="@color/axf_text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMisReportes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>

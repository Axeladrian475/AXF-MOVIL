<?xml version="1.0" encoding="utf-8"?>
<!--
    item_mi_reporte.xml — Tarjeta de mis reportes
    ANTES: cardBackgroundColor #FFFFFF — inconsistente con app dark
    AHORA: axf_bg_card — paleta dark unificada
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/axf_bg_card"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Categoría + Privado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvMiCategoriaReporte"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/axf_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMiPrivado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/axf_text_tertiary"/>
        </LinearLayout>

        <!-- Sucursal -->
        <TextView
            android:id="@+id/tvMiSucursalReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/axf_orange"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Descripción -->
        <TextView
            android:id="@+id/tvMiDescripcionReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/axf_text_primary"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"/>

        <!-- Personal reportado (si aplica) -->
        <TextView
            android:id="@+id/tvMiPersonalReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/axf_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <!-- Fila: Estado + Fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvMiEstadoReporte"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMiFechaReporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Strikes -->
        <TextView
            android:id="@+id/tvMiStrikes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/axf_error"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <!-- Botón reenviar a Sucursal (visible solo con 3+ strikes y no reenviado) -->
        <Button
            android:id="@+id/btnReenviarSucursal"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="📩 Reenviar reporte a Sucursal"
            android:textColor="@color/axf_text_primary"
            android:backgroundTint="@color/axf_orange"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:stateListAnimator="@null"
            android:visibility="gone"/>

        <!-- Etiqueta de ya reenviado -->
        <TextView
            android:id="@+id/tvYaReenviado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Reporte reenviado a Sucursal"
            android:textColor="#27AE60"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

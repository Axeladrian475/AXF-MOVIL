<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_chat.xml — Pantalla de chat
    ANTES: fondo #F2F2F2 (claro) → AHORA: axf_bg_deep (oscuro)
    Sin emojis. Íconos vectoriales. Paleta unificada.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/axf_chat_bg">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/axf_bg_primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnVolver"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Volver"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvNombreChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvEscribiendo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="escribiendo..."
                android:textColor="@color/axf_orange"
                android:textSize="11sp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── LISTA DE MENSAJES ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMensajes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- ── BANNER REPLY/EDITAR ── -->
    <LinearLayout
        android:id="@+id/llReply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/axf_bg_card"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@color/axf_orange"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvReplyDe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/axf_orange"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvReplyContenido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/axf_text_secondary"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCancelarReply"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/axf_text_secondary"/>
    </LinearLayout>

    <!-- ── BARRA DE ENTRADA ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/axf_chat_bar_bg"
        android:padding="10dp"
        android:elevation="8dp">

        <EditText
            android:id="@+id/etMensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Escribe un mensaje..."
            android:background="@drawable/bg_input"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="@color/axf_text_primary"
            android:textColorHint="@color/axf_text_hint"
            android:maxLines="4"
            android:inputType="textMultiLine|textCapSentences"/>

        <ImageButton
            android:id="@+id/btnEnviar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_card_orange"
            android:contentDescription="Enviar"
            android:padding="10dp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    item_mensaje_enviado.xml — Burbuja de mensaje enviado
    Burbuja: naranja AxF (axf_bubble_sent = #F26A21)
    Fondo de lista: axf_chat_bg (#070E1A)
    Texto de burbuja: blanco para contraste con fondo naranja
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/llBurbuja"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:background="@drawable/bg_burbuja_enviado"
        android:padding="10dp"
        android:maxWidth="280dp">

        <!-- Reply/Cita -->
        <LinearLayout
            android:id="@+id/llReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/axf_bubble_reply_bg"
            android:padding="6dp"
            android:layout_marginBottom="6dp"
            android:paddingStart="8dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvReplyDe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#FFCC88"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvReplyContenido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#DDDDDD"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvContenido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/axf_text_primary"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end"
            android:layout_marginTop="3dp">
            <TextView
                android:id="@+id/tvEditado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="editado"
                android:textSize="9sp"
                android:textColor="#DDDDDD"
                android:textStyle="italic"
                android:layout_marginEnd="4dp"
                android:visibility="gone"/>
            <TextView
                android:id="@+id/tvHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#DDDDDD"/>
            <TextView
                android:id="@+id/tvTicks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginStart="4dp"
                android:textColor="#DDDDDD"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>

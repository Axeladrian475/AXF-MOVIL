<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/axf_bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/axf_bg_surface">

        <TextView
            android:id="@+id/btnHistorialBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="@color/axf_orange"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistorialNombreEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Ejercicio"
                android:textColor="@color/axf_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvHistorialGrupoMuscular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grupo muscular"
                android:textColor="@color/axf_orange"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- PRs y estadísticas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/axf_bg_surface"
        android:layout_marginTop="2dp">

        <!-- PR Peso -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 MEJOR PESO"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="9sp"
                android:letterSpacing="0.12"/>
            <TextView
                android:id="@+id/tvPrPeso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- kg"
                android:textColor="@color/axf_orange"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/axf_divider"/>

        <!-- Total sesiones -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 SESIONES"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="9sp"
                android:letterSpacing="0.12"/>
            <TextView
                android:id="@+id/tvTotalSesiones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/axf_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/axf_divider"/>

        <!-- PR Volumen -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ MAX VOLUMEN"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="9sp"
                android:letterSpacing="0.12"/>
            <TextView
                android:id="@+id/tvPrVolumen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- kg"
                android:textColor="@color/axf_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressHistorial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="gone"/>

    <!-- Lista de sesiones -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/containerSesiones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

</LinearLayout>

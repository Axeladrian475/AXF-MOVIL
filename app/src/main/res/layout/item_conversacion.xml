<?xml version="1.0" encoding="utf-8"?>
<!--
    item_conversacion.xml — Tarjeta de conversación en lista
    ANTES: cardView blanco con texto oscuro → inconsistente con la app dark
    AHORA: card color axf_bg_card para encajar en pantalla oscura
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/axf_bg_card"
    android:layout_margin="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Avatar circular con inicial -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:textColor="@color/axf_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_card_orange"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvNombrePersonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvPuesto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_orange"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvUltimoMensaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Badge no leídos -->
        <TextView
            android:id="@+id/tvNoLeidos"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:textColor="@color/axf_text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_card_orange"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#071B2F"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDietasBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← "
            android:textColor="#F26A21"
            android:textSize="20sp"
            android:paddingEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mis Dietas"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="@font/jockey_one"/>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvDietasVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tienes dietas asignadas aún."
        android:textColor="#888888"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone"/>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDietas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"/>

</LinearLayout>

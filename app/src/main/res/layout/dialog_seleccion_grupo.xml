<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_dark"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <!-- Ícono + título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <!-- Ícono circular naranja -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_serie_num_circle"
            android:gravity="center"
            android:layout_marginEnd="14dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_entreno"
                android:tint="@color/axf_orange"
                android:contentDescription="Entreno"/>
        </LinearLayout>

        <!-- Textos de cabecera -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECCIONA MÚSCULO"
                android:textColor="@color/axf_orange"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvRutinaNombreDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOY ENTRENAS"
                android:textColor="@color/axf_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvRutinaFechaDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13 mayo 2026"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/axf_bg_surface"
        android:layout_marginBottom="16dp"/>

    <!-- Pregunta -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Qué músculo vas a entrenar hoy?"
        android:textColor="@color/axf_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="12dp"/>

    <!-- Botones de bloques (dinámicos) -->
    <LinearLayout
        android:id="@+id/containerGrupos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

</LinearLayout>
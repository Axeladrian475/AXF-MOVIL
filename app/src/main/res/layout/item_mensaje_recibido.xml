<?xml version="1.0" encoding="utf-8"?>
<!--
    item_mensaje_recibido.xml — Burbuja de mensaje recibido
    ANTES: burbuja blanca (#FFFFFF) → inconsistente en pantalla dark
    AHORA: burbuja axf_bg_surface (#1A2A3F), texto blanco
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/llBurbuja"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="60dp"
        android:orientation="vertical"
        android:background="@drawable/bg_burbuja_recibido"
        android:padding="10dp"
        android:maxWidth="280dp">

        <LinearLayout
            android:id="@+id/llReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/axf_bubble_reply_bg"
            android:padding="6dp"
            android:layout_marginBottom="6dp"
            android:paddingStart="8dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvReplyDe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/axf_orange"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvReplyContenido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/axf_text_secondary"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvContenido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/axf_text_primary"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end"
            android:layout_marginTop="3dp">
            <TextView
                android:id="@+id/tvEditado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="editado"
                android:textSize="9sp"
                android:textColor="@color/axf_text_secondary"
                android:textStyle="italic"
                android:layout_marginEnd="4dp"
                android:visibility="gone"/>
            <TextView
                android:id="@+id/tvHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/axf_text_secondary"/>
            <TextView
                android:id="@+id/tvTicks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginStart="4dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>

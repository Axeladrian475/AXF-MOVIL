<?xml version="1.0" encoding="utf-8"?>
<!--
    item_personal_seleccion.xml
    Tarjeta de personal para el selector en "Reporte de Personal".
    Muestra foto circular, nombre completo, puesto y un indicador de selección.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/axf_bg_card"
    android:layout_marginStart="0dp"
    android:layout_marginEnd="0dp"
    android:layout_marginBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Avatar circular: foto real o inicial como fallback -->
        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="50dp">

            <!-- Foto real (Glide la carga aquí) -->
            <ImageView
                android:id="@+id/ivAvatarPersonal"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle"
                android:clipToOutline="true"
                android:contentDescription="Foto de perfil"/>

            <!-- Inicial como fallback cuando no hay foto -->
            <TextView
                android:id="@+id/tvInicialPersonal"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:textColor="@color/axf_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_card_orange"/>
        </FrameLayout>

        <!-- Nombre y puesto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvNombrePersonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvPuestoPersonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/axf_orange"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Indicador de selección -->
        <ImageView
            android:id="@+id/ivSeleccionado"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/btn_radio"
            android:contentDescription="Seleccionado"
            android:visibility="invisible"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

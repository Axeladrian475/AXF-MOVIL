<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111827"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="12dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvDietaFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#F26A21"
        android:textSize="15sp"
        android:fontFamily="@font/jockey_one"/>

    <TextView
        android:id="@+id/tvDietaNutriologo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nutriólogo: —"
        android:textColor="#CCCCCC"
        android:textSize="13sp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvDietaComidas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="— comidas"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ver detalle →"
            android:textColor="#F26A21"
            android:textSize="12sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/btnEliminarDieta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑️  Eliminar"
            android:textColor="@color/axf_error"
            android:textSize="12sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingStart="8dp"/>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1A2838">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Agregar Consumo"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Qué comiste?"
        android:textColor="#8B9EB7"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etConsumoDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej. 2 rebanadas de pizza"
        android:textColor="#FFFFFF"
        android:textColorHint="#5B6D87"
        android:backgroundTint="#E87722"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calorías estimadas (opcional)"
        android:textColor="#8B9EB7"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etConsumoCalorias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej. 350"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF"
        android:textColorHint="#5B6D87"
        android:backgroundTint="#E87722"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancelarConsumo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#8B9EB7"/>

        <Button
            android:id="@+id/btnGuardarConsumo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guardar"
            android:backgroundTint="#E87722"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>

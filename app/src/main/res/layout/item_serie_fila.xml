<?xml version="1.0" encoding="utf-8"?>
<!--
    item_serie_fila.xml — Fila de serie en ejercicio (REDISEÑO PREMIUM v2)
    Cambios: número de serie en círculo con borde naranja, inputs con bordes
    redondeados v2, fondo alterno oscuro, check button más grande.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:background="@color/axf_entreno_card">

    <!-- Número de serie (círculo con borde naranja) -->
    <TextView
        android:id="@+id/tvSerieNum"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="1"
        android:textColor="@color/axf_orange"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_serie_num_circle"/>

    <!-- Anterior (preset de la rutina) -->
    <TextView
        android:id="@+id/tvAnterior"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="—"
        android:textColor="@color/axf_text_tertiary"
        android:textSize="13sp"
        android:layout_marginStart="14dp"/>

    <!-- Campo KG -->
    <EditText
        android:id="@+id/etPesoSerie"
        android:layout_width="68dp"
        android:layout_height="40dp"
        android:hint="kg"
        android:inputType="numberDecimal"
        android:textColor="@color/axf_text_primary"
        android:textColorHint="@color/axf_text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:background="@drawable/bg_input_serie_v2"
        android:layout_marginEnd="8dp"/>

    <!-- Campo REPS -->
    <EditText
        android:id="@+id/etRepsSerie"
        android:layout_width="58dp"
        android:layout_height="40dp"
        android:hint="reps"
        android:inputType="number"
        android:textColor="@color/axf_text_primary"
        android:textColorHint="@color/axf_text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:background="@drawable/bg_input_serie_v2"
        android:layout_marginEnd="8dp"/>

    <!-- Check button -->
    <ImageButton
        android:id="@+id/btnCheckSerie"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_check_empty"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Completar serie"
        android:padding="4dp"/>

</LinearLayout>

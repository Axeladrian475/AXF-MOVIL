<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Pantalla principal (Dashboard)
    Design system AxF: fondo axf_bg_deep, header axf_bg_primary,
    navegación inferior dark unificada, sin emojis.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/axf_bg_deep">

    <!-- CONTENIDO SCROLLEABLE -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ── -->
            <LinearLayout
                android:id="@+id/mainHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/axf_bg_primary"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="30dp"
                        android:src="@drawable/logo_axf"
                        android:scaleType="fitStart"
                        android:contentDescription="AxF GymNet"
                        tools:ignore="MissingConstraints"/>

                    <TextView
                        android:id="@+id/tvNombreUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bienvenido"
                        android:textColor="@color/axf_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Días restantes -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/axf_bg_surface"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        app:cornerRadius="6dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_fire"
                            android:contentDescription="Días restantes"/>

                        <TextView
                            android:id="@+id/tvDiasRestantes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- Días"
                            android:textColor="@color/axf_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="5dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="restantes de tu suscripción"
                        android:textColor="@color/axf_text_secondary"
                        android:textSize="8sp"
                        android:layout_marginTop="2dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Botón Cerrar Sesión -->
                <ImageView
                    android:id="@+id/btnCerrarSesion"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_logout"
                    android:contentDescription="Cerrar sesión"
                    android:tint="@color/axf_text_secondary"
                    android:padding="6dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_nav_item"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- ── CONTENIDO PRINCIPAL ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">

                <!-- TARJETA SUSCRIPCIÓN -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado de suscripción"
                            android:textColor="@color/axf_text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Estado ACTIVA/INACTIVA -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:id="@+id/tvEstadoIcono"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_check_circle"
                                    android:contentDescription="Estado suscripción"
                                    android:layout_marginEnd="10dp"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvEstadoSuscripcion"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="ACTIVA"
                                        android:textColor="@color/axf_success"
                                        android:textSize="18sp"
                                        android:textStyle="bold"/>

                                    <TextView
                                        android:id="@+id/tvVencimiento"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Vence: --/--/----"
                                        android:textColor="@color/axf_text_secondary"
                                        android:textSize="11sp"/>

                                    <TextView
                                        android:id="@+id/tvTipoPlan"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text=""
                                        android:textColor="@color/axf_orange"
                                        android:textSize="11sp"
                                        android:textStyle="bold"/>

                                </LinearLayout>
                            </LinearLayout>

                            <!-- Puntos con ícono estrella -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@color/axf_bg_surface"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="6dp"
                                android:paddingBottom="6dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_star"
                                    android:contentDescription="Puntos"/>

                                <TextView
                                    android:id="@+id/tvPuntos"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 Pts"
                                    android:textColor="@color/axf_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginStart="6dp"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Sesiones de nutriólogo y entrenador -->
                        <View
                            android:id="@+id/separatorSesiones"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/axf_divider"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone"/>

                        <LinearLayout
                            android:id="@+id/llSesiones"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false"
                            android:visibility="gone">

                            <!-- Nutriólogo -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/bg_stats_pill"
                                android:padding="12dp"
                                android:layout_marginEnd="6dp">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_nav_dieta"
                                    app:tint="@color/axf_orange"
                                    android:layout_marginEnd="8dp"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Nutriólogo"
                                        android:textColor="@color/axf_text_secondary"
                                        android:textSize="11sp"/>
                                    <TextView
                                        android:id="@+id/tvSesionesNutriologo"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 Sesiones"
                                        android:textColor="@color/axf_text_primary"
                                        android:textSize="14sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Entrenador -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/bg_stats_pill"
                                android:padding="12dp"
                                android:layout_marginStart="6dp">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_nav_entreno"
                                    app:tint="@color/axf_orange"
                                    android:layout_marginEnd="8dp"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Entrenador"
                                        android:textColor="@color/axf_text_secondary"
                                        android:textSize="11sp"/>
                                    <TextView
                                        android:id="@+id/tvSesionesEntrenador"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 Sesiones"
                                        android:textColor="@color/axf_text_primary"
                                        android:textSize="14sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- TARJETA RACHA DE ASISTENCIA -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Fila superior: llama + número + estado -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:src="@drawable/ic_fire"
                                android:contentDescription="Racha"
                                android:layout_marginEnd="14dp"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvRachaDias"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/axf_orange"
                                    android:textSize="40sp"
                                    android:textStyle="bold"
                                    android:lineSpacingExtra="-6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Días de racha"
                                    android:textColor="@color/axf_text_secondary"
                                    android:textSize="12sp"/>
                            </LinearLayout>

                            <!-- Badge de estado -->
                            <TextView
                                android:id="@+id/tvRachaEstado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin racha"
                                android:textColor="@color/axf_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:background="@color/axf_bg_surface"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"/>
                        </LinearLayout>

                        <!-- Asistencia semanal (debajo de días de racha) -->
                        <LinearLayout
                            android:id="@+id/llAsistenciaSemana"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stats_pill"
                            android:padding="12dp"
                            android:layout_marginBottom="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Esta semana"
                                        android:textColor="@color/axf_text_primary"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>

                                    <TextView
                                        android:id="@+id/tvAsistenciaSemana"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 de 7 asistencias"
                                        android:textColor="@color/axf_text_secondary"
                                        android:textSize="11sp"
                                        android:layout_marginTop="2dp"/>

                                    <TextView
                                        android:id="@+id/tvResetSemana"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Se restablece cada domingo"
                                        android:textColor="@color/axf_text_tertiary"
                                        android:textSize="10sp"
                                        android:layout_marginTop="4dp"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingStart="8dp">

                                    <TextView
                                        android:id="@+id/tvFaltasRestantes"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="@color/axf_orange"
                                        android:textSize="26sp"
                                        android:textStyle="bold"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="faltas\ndisponibles"
                                        android:textColor="@color/axf_text_secondary"
                                        android:textSize="9sp"
                                        android:gravity="center"
                                        android:lineSpacingExtra="-2dp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvVisitasPendientes"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@color/axf_bg_surface"
                                android:padding="8dp"
                                android:text="Te quedan 5 visitas posibles al gym esta semana"
                                android:textColor="@color/axf_success"
                                android:textSize="11sp"
                                android:gravity="center"/>
                        </LinearLayout>

                        <!-- Separador -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/axf_divider"
                            android:layout_marginBottom="12dp"/>

                        <!-- Puntos de racha -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Puntos por racha"
                                    android:textColor="@color/axf_text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvRachaProgresoMes"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0/30 días para bonus mensual"
                                    android:textColor="@color/axf_text_secondary"
                                    android:textSize="11sp"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvRachaPuntosDia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐ +10 pts/día"
                                android:textColor="@color/axf_orange"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Separador 2 -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/axf_divider"
                            android:layout_marginBottom="12dp"/>

                        <!-- Días de descanso -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Días de descanso"
                                    android:textColor="@color/axf_text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Faltas permitidas por semana (resetea domingo)"
                                    android:textColor="@color/axf_text_secondary"
                                    android:textSize="11sp"/>
                            </LinearLayout>

                            <!-- Botón − -->
                            <Button
                                android:id="@+id/btnDescansoMenos"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="−"
                                android:textColor="@color/axf_text_primary"
                                android:textSize="20sp"
                                android:backgroundTint="@color/axf_bg_surface"
                                android:padding="0dp"
                                android:stateListAnimator="@null"
                                android:minWidth="0dp"
                                android:minHeight="0dp"/>

                            <TextView
                                android:id="@+id/tvDiasDescanso"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/axf_text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"/>

                            <!-- Botón + -->
                            <Button
                                android:id="@+id/btnDescansoMas"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="+"
                                android:textColor="@color/axf_orange"
                                android:textSize="20sp"
                                android:backgroundTint="@color/axf_bg_surface"
                                android:padding="0dp"
                                android:stateListAnimator="@null"
                                android:minWidth="0dp"
                                android:minHeight="0dp"/>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- TARJETA MIS DATOS FÍSICOS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDatosFisicos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="16dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_fire"
                            app:tint="@color/axf_orange"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mis Metas y Datos Físicos"
                                android:textColor="@color/axf_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Peso, grasa, músculo e historial"
                                android:textColor="@color/axf_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/axf_text_secondary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- TARJETA AFORO / HORARIOS PICO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvNombreSucursal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Afluencia en AxF"
                            android:textColor="@color/axf_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:padding="4dp"
                            android:background="?attr/selectableItemBackground"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Horarios pico (promedio)"
                            android:textColor="@color/axf_text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"/>

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/barChart"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"/>

                        <!-- Separador -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/axf_divider"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp"/>

                        <!-- Título aforo en tiempo real -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 Aforo en tiempo real"
                            android:textColor="@color/axf_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <!-- Fila: personas / capacidad + porcentaje -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:id="@+id/tvAforo"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="— / — personas"
                                android:textColor="@color/axf_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:visibility="visible"/>

                            <TextView
                                android:id="@+id/tvAforoPct"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/axf_orange"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Barra de progreso aforo -->
                        <ProgressBar
                            android:id="@+id/progressAforo"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/axf_orange"
                            android:progressBackgroundTint="@color/axf_divider"
                            android:layout_marginBottom="4dp"/>

                        <!-- Última actualización -->
                        <TextView
                            android:id="@+id/tvAforoHora"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/axf_text_tertiary"
                            android:textSize="10sp"
                            android:layout_marginBottom="10dp"/>

                        <!-- Botón actualizar -->
                        <Button
                            android:id="@+id/btnActualizarAforo"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="↻ Actualizar aforo"
                            android:backgroundTint="@color/axf_bg_primary"
                            android:textColor="@color/axf_orange"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"
                            android:stateListAnimator="@null"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ── BARRA DE NAVEGACIÓN INFERIOR ── -->
    <LinearLayout
        android:id="@+id/mainNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/axf_bg_primary"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="12dp"
        android:layout_gravity="bottom">

        <!-- Inicio -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_home"
                android:contentDescription="Inicio"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="9sp"
                android:textColor="@color/axf_nav_active"/>
        </LinearLayout>

        <!-- Entreno -->
        <LinearLayout
            android:id="@+id/navEntreno"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_entreno"
                android:contentDescription="Entreno"
                android:tint="@color/axf_nav_inactive"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entreno"
                android:textSize="9sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

        <!-- Dieta -->
        <LinearLayout
            android:id="@+id/navDieta"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_dieta"
                android:contentDescription="Dieta"
                android:tint="@color/axf_nav_inactive"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dieta"
                android:textSize="9sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

        <!-- Chat -->
        <LinearLayout
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chat_nav"
                    android:contentDescription="Chat"
                    android:tint="@color/axf_nav_inactive"/>
                <TextView
                    android:id="@+id/tvChatBadge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_card_orange"
                    android:gravity="center"
                    android:textColor="@color/axf_text_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvNavChatLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textSize="9sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

        <!-- Reportar -->
        <LinearLayout
            android:id="@+id/navReportar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_reportar"
                android:contentDescription="Reportar"
                android:tint="@color/axf_nav_inactive"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reportar"
                android:textSize="9sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

        <!-- Tienda (Suscripciones y Promociones) -->
        <LinearLayout
            android:id="@+id/navTienda"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_tienda"
                android:contentDescription="Tienda"
                android:tint="@color/axf_nav_inactive"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tienda"
                android:textSize="9sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Pantalla principal (Dashboard)
    Design system AxF: fondo axf_bg_deep, header axf_bg_primary,
    navegación inferior dark unificada, sin emojis.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/axf_bg_deep">

    <!-- CONTENIDO SCROLLEABLE -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/axf_bg_primary"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="30dp"
                        android:src="@drawable/logo_axf"
                        android:scaleType="fitStart"
                        android:contentDescription="AxF GymNet"
                        tools:ignore="MissingConstraints"/>

                    <TextView
                        android:id="@+id/tvNombreUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bienvenido"
                        android:textColor="@color/axf_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Días restantes (chip oscuro con ícono de llama) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/axf_bg_surface"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_fire"
                        android:contentDescription="Días restantes"/>

                    <TextView
                        android:id="@+id/tvDiasRestantes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- Días"
                        android:textColor="@color/axf_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="5dp"/>
                </LinearLayout>

                <!-- Notificaciones -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_bell"
                    android:contentDescription="Notificaciones"
                    android:padding="4dp"/>

            </LinearLayout>

            <!-- ── CONTENIDO PRINCIPAL ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">

                <!-- TARJETA SUSCRIPCIÓN -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado de suscripción"
                            android:textColor="@color/axf_text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Estado ACTIVA/INACTIVA -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:id="@+id/tvEstadoIcono"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_check_circle"
                                    android:contentDescription="Estado suscripción"
                                    android:layout_marginEnd="10dp"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvEstadoSuscripcion"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="ACTIVA"
                                        android:textColor="@color/axf_success"
                                        android:textSize="18sp"
                                        android:textStyle="bold"/>

                                    <TextView
                                        android:id="@+id/tvVencimiento"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Vence: --/--/----"
                                        android:textColor="@color/axf_text_secondary"
                                        android:textSize="11sp"/>

                                    <TextView
                                        android:id="@+id/tvTipoPlan"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text=""
                                        android:textColor="@color/axf_orange"
                                        android:textSize="11sp"
                                        android:textStyle="bold"/>

                                </LinearLayout>
                            </LinearLayout>

                            <!-- Puntos con ícono estrella -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@color/axf_bg_surface"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="6dp"
                                android:paddingBottom="6dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_star"
                                    android:contentDescription="Puntos"/>

                                <TextView
                                    android:id="@+id/tvPuntos"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 Pts"
                                    android:textColor="@color/axf_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginStart="6dp"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- TARJETA AFORO / HORARIOS PICO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/axf_bg_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvNombreSucursal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Afluencia en AxF"
                            android:textColor="@color/axf_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Horarios pico (promedio)"
                            android:textColor="@color/axf_text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"/>

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/barChart"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"/>

                        <Button
                            android:id="@+id/btnActualizarAforo"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Actualizar aforo actual"
                            android:backgroundTint="@color/axf_success"
                            android:textColor="@color/axf_text_primary"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="12dp"
                            android:stateListAnimator="@null"/>

                        <TextView
                            android:id="@+id/tvAforo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/axf_text_primary"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"
                            android:visibility="gone"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── BARRA DE NAVEGACIÓN INFERIOR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/axf_bg_primary"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="12dp"
        android:layout_gravity="bottom">

        <!-- Inicio -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_home"
                android:contentDescription="Inicio"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="10sp"
                android:textColor="@color/axf_nav_active"/>
        </LinearLayout>

        <!-- Entreno -->
        <LinearLayout
            android:id="@+id/navEntreno"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_entreno"
                android:contentDescription="Entreno"
                android:tint="@color/axf_nav_inactive"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entreno"
                android:textSize="10sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

        <!-- Dieta -->
        <LinearLayout
            android:id="@+id/navDieta"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_dieta"
                android:contentDescription="Dieta"
                android:tint="@color/axf_nav_inactive"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dieta"
                android:textSize="10sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

        <!-- Chat -->
        <LinearLayout
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chat_nav"
                    android:contentDescription="Chat"
                    android:tint="@color/axf_nav_inactive"/>
                <TextView
                    android:id="@+id/tvChatBadge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_card_orange"
                    android:gravity="center"
                    android:textColor="@color/axf_text_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvNavChatLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textSize="10sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

        <!-- Reportar -->
        <LinearLayout
            android:id="@+id/navReportar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_item">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_reportar"
                android:contentDescription="Reportar"
                android:tint="@color/axf_nav_inactive"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reportar"
                android:textSize="10sp"
                android:textColor="@color/axf_nav_inactive"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

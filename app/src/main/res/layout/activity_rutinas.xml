<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_rutinas.xml — Lista de rutinas
    ANTES: fondo #F2F2F2 (claro), ImageButton con ic_media_previous
    AHORA: fondo axf_bg_deep, ic_back, paleta unificada
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/axf_bg_deep">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/axf_bg_primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            android:padding="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mis Rutinas"
            android:textColor="@color/axf_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- ── PROGRESS ── -->
    <ProgressBar
        android:id="@+id/progressRutinas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:indeterminateTint="@color/axf_orange"
        android:visibility="gone"
        style="?android:attr/progressBarStyle"/>

    <!-- ── VACÍO ── -->
    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tienes rutinas asignadas aún"
        android:textColor="@color/axf_text_secondary"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- ── LISTA DE RUTINAS ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/containerRutinas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"/>

    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    item_ejercicio_entreno.xml — Ítem de ejercicio en pantalla de entreno (REDISEÑO PREMIUM v2)
    Cambios: card con border-radius 16dp y borde sutil, thumbnail circular con fondo icon,
    header del ejercicio con nombre grande, tabla de series con encabezado mejor alineado,
    botón "Agregar Serie" como texto con borde naranja.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/axf_entreno_card"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER DEL EJERCICIO ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="10dp">

            <!-- Thumbnail circular -->
            <ImageView
                android:id="@+id/imgEjercicio"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_nav_entreno"
                android:tint="@color/axf_orange"
                android:background="@drawable/bg_ejercicio_thumb"
                android:scaleType="center"
                android:padding="10dp"
                android:layout_marginEnd="14dp"
                android:contentDescription="Imagen ejercicio"/>

            <!-- Nombre + chip de descanso -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreEjercicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jalón al Pecho (Cable)"
                    android:textColor="@color/axf_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <!-- Chip de descanso inline bajo el nombre -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:tint="@color/axf_orange"
                        android:contentDescription="Descanso"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/tvDescanso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descanso: 2min"
                        android:textColor="@color/axf_orange"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Menú contextual ⋮ -->
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="⋮"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="22sp"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Notas técnicas (hidden por defecto) -->
        <TextView
            android:id="@+id/tvNotasTecnicas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/axf_text_secondary"
            android:textSize="13sp"
            android:paddingStart="78dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:visibility="gone"/>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0A1525"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <!-- ── ENCABEZADO TABLA DE SERIES ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#080F1C">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="SERIE"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ANTERIOR"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"/>

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="KG"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.06"/>

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="REPS"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.06"/>

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="OK"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.06"/>
        </LinearLayout>

        <!-- ── FILAS DE SERIES (dinámico) ── -->
        <LinearLayout
            android:id="@+id/tablaSeries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <!-- ── BOTÓN AGREGAR SERIE ── -->
        <TextView
            android:id="@+id/btnAgregarSerie"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="+ Agregar Serie"
            android:textColor="@color/axf_orange"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_tag_orange"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>

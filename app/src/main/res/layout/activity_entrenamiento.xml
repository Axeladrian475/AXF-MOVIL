<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_entrenamiento.xml — Pantalla de entrenamiento activo (REDISEÑO PREMIUM v2)
    Cambios: stats bar con pills individuales, header más moderno, FAB de terminar,
    botones inferiores con mayor contraste y rounding.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/axf_entreno_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER TOP BAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/axf_bg_primary"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="16dp">

                <!-- Fila superior: título + botón terminar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SESIÓN ACTIVA"
                            android:textColor="@color/axf_orange"
                            android:textSize="10sp"
                            android:letterSpacing="0.12"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Entreno en curso"
                            android:textColor="@color/axf_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnTerminar"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Terminar"
                        android:background="@drawable/bg_btn_orange_rounded"
                        android:textColor="@color/axf_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:stateListAnimator="@null"/>

                </LinearLayout>

                <!-- Separador naranja -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="@color/axf_orange"
                    android:layout_marginTop="14dp"/>

            </LinearLayout>

            <!-- ── STATS BAR — 3 pills ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- Pill Duración -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stats_pill"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURACIÓN"
                        android:textColor="@color/axf_text_tertiary"
                        android:textSize="9sp"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvDuracion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textColor="@color/axf_orange"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Pill Volumen -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stats_pill"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOLUMEN"
                        android:textColor="@color/axf_text_tertiary"
                        android:textSize="9sp"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvVolumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kg"
                        android:textColor="@color/axf_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Pill Series -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stats_pill"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERIES"
                        android:textColor="@color/axf_text_tertiary"
                        android:textSize="9sp"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvSeriesTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/axf_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Separador visual entre stats y ejercicios -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0D1F35"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"/>

            <!-- ── EJERCICIOS ── -->
            <LinearLayout
                android:id="@+id/containerEjercicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"/>

            <!-- ── BOTONES FINALES ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

                <Button
                    android:id="@+id/btnConfiguracion"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Configuración"
                    android:background="@drawable/bg_stats_pill"
                    android:textColor="@color/axf_text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnDescartar"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Descartar entreno"
                    android:background="@drawable/bg_stats_pill"
                    android:textColor="@color/axf_error"
                    android:textSize="13sp"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

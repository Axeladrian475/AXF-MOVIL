<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_entrenamiento.xml — Pantalla de entrenamiento activo
    ANTES: fondo #121212, azules iOS (#007AFF), botón "Terminar" azul
    AHORA: fondo axf_bg_deep, acento axf_orange unificado
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/axf_entreno_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER TOP BAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/axf_bg_primary"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="44dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/arrow_down_float"
                    android:tint="@color/axf_text_secondary"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Minimizar"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Entreno activo"
                    android:textColor="@color/axf_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:tint="@color/axf_text_secondary"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Tiempo"/>

                <Button
                    android:id="@+id/btnTerminar"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Terminar"
                    android:backgroundTint="@color/axf_orange"
                    android:textColor="@color/axf_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

            <!-- ── STATS BAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/axf_bg_card"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURACIÓN"
                        android:textColor="@color/axf_text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"/>
                    <TextView
                        android:id="@+id/tvDuracion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0s"
                        android:textColor="@color/axf_orange"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOLUMEN"
                        android:textColor="@color/axf_text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"/>
                    <TextView
                        android:id="@+id/tvVolumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kg"
                        android:textColor="@color/axf_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERIES"
                        android:textColor="@color/axf_text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"/>
                    <TextView
                        android:id="@+id/tvSeriesTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/axf_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ── EJERCICIOS ── -->
            <LinearLayout
                android:id="@+id/containerEjercicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"/>

            <!-- ── BOTONES FINALES ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <Button
                    android:id="@+id/btnConfiguracion"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Configuración"
                    android:backgroundTint="@color/axf_bg_surface"
                    android:textColor="@color/axf_text_primary"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnDescartar"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Descartar entreno"
                    android:backgroundTint="@color/axf_bg_surface"
                    android:textColor="@color/axf_error"
                    android:textSize="13sp"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

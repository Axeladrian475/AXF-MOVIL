<?xml version="1.0" encoding="utf-8"?>
<!--
    item_reporte_publico.xml — Tarjeta de reporte público
    ANTES: cardBackgroundColor #FFFFFF (blanco claro) — inconsistente
    AHORA: axf_bg_card — paleta dark unificada
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/axf_bg_card"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Categoría + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvCategoriaReporte"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/axf_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvEstadoReporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/axf_text_secondary"/>
        </LinearLayout>

        <!-- Descripción -->
        <TextView
            android:id="@+id/tvDescripcionReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/axf_text_primary"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="8dp"/>

        <!-- Sumados -->
        <TextView
            android:id="@+id/tvSumados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/axf_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <!-- Strikes -->
        <TextView
            android:id="@+id/tvStrikes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/axf_error"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <!-- Botón sumar -->
        <Button
            android:id="@+id/btnSumarReporte"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Sumarme al reporte"
            android:textColor="@color/axf_text_primary"
            android:backgroundTint="@color/axf_orange"
            android:textSize="13sp"
            android:stateListAnimator="@null"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

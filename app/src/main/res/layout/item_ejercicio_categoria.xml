<?xml version="1.0" encoding="utf-8"?>
<!--
    item_ejercicio_categoria.xml — Tarjeta de ejercicio dentro de una sección por grupo muscular
    Muestra: nombre del ejercicio, series×reps, peso, entrenador/rutina de origen, botón empezar.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/axf_bg_card"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Barra accent naranja izquierda -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/axf_orange"/>

        <!-- Contenido del ejercicio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Nombre del ejercicio -->
            <TextView
                android:id="@+id/tvEjNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Press de Banca"
                android:textColor="@color/axf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <!-- Fila: Series × Reps + Peso -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <!-- Badge Series×Reps -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_muscle_badge"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tvEjSeriesReps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 × 12"
                        android:textColor="@color/axf_orange"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Peso sugerido -->
                <TextView
                    android:id="@+id/tvEjPeso"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="· 60 kg sugerido"
                    android:textColor="@color/axf_text_tertiary"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Rutina de origen (entrenador + nombre rutina) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@color/axf_text_tertiary"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvEjRutinaOrigen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="De: Pecho y Espalda · Entrenador X"
                    android:textColor="@color/axf_text_tertiary"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Botón Empezar Rutina -->
            <Button
                android:id="@+id/btnEmpezarEjercicio"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="▶  Empezar Rutina"
                android:background="@drawable/bg_btn_orange_rounded"
                android:textColor="@color/axf_text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:stateListAnimator="@null"
                android:letterSpacing="0.02"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<!--
    item_ejercicio_categoria.xml — Tarjeta de ejercicio dentro de una sección por día/rutina.
    Muestra: imagen del ejercicio, nombre, series×reps, descanso, notas técnicas, botón empezar.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/axf_bg_card"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Fila superior: imagen + datos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="0dp">

            <!-- Barra accent naranja izquierda -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/axf_orange"/>

            <!-- Imagen del ejercicio -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_card_orange"
                android:clipToOutline="true">

                <!-- Foto real (Glide) -->
                <ImageView
                    android:id="@+id/ivEjImagen"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_card_orange"
                    android:clipToOutline="true"
                    android:contentDescription="Imagen del ejercicio"/>

                <!-- Fallback: ícono musculo -->
                <TextView
                    android:id="@+id/tvEjImagenFallback"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:gravity="center"
                    android:text="💪"
                    android:textSize="28sp"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Datos del ejercicio -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="14dp">

                <!-- Nombre del ejercicio -->
                <TextView
                    android:id="@+id/tvEjNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Press de Banca"
                    android:textColor="@color/axf_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- Fila: badge Series×Reps + Descanso -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_muscle_badge"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:id="@+id/tvEjSeriesReps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 × 10"
                            android:textColor="@color/axf_orange"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Descanso -->
                    <TextView
                        android:id="@+id/tvEjDescanso"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="60s descanso"
                        android:textColor="@color/axf_text_tertiary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Peso sugerido -->
                <TextView
                    android:id="@+id/tvEjPeso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="· Peso libre"
                    android:textColor="@color/axf_text_tertiary"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>

                <!-- Rutina de origen -->
                <TextView
                    android:id="@+id/tvEjRutinaOrigen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="De: Rutina · Entrenador"
                    android:textColor="@color/axf_text_tertiary"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Notas técnicas (visible solo si hay contenido) -->
        <TextView
            android:id="@+id/tvEjNotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="92dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="0dp"
            android:textColor="@color/axf_text_secondary"
            android:textSize="11sp"
            android:fontFamily="sans-serif-light"
            android:lineSpacingExtra="2dp"
            android:visibility="gone"/>

        <!-- Botón Empezar -->
        <Button
            android:id="@+id/btnEmpezarEjercicio"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:text="▶  Empezar Rutina"
            android:background="@drawable/bg_btn_orange_rounded"
            android:textColor="@color/axf_text_primary"
            android:textStyle="bold"
            android:textSize="13sp"
            android:stateListAnimator="@null"
            android:letterSpacing="0.02"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
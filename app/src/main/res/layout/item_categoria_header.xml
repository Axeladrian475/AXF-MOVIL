<?xml version="1.0" encoding="utf-8"?>
<!--
    item_categoria_header.xml — Encabezado de sección por grupo muscular
    Muestra el nombre del grupo (ej: PECHO), el ícono de categoría y el conteo de ejercicios.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="24dp"
    android:layout_marginBottom="10dp">

    <!-- Fila principal del header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_category_header"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Ícono círculo naranja -->
        <LinearLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_serie_num_circle"
            android:gravity="center"
            android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_nav_entreno"
                android:tint="@color/axf_orange"
                android:contentDescription="Grupo muscular"/>
        </LinearLayout>

        <!-- Nombre del grupo muscular -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GRUPO MUSCULAR"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvCategoriaNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PECHO"
                android:textColor="@color/axf_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Badge conteo de ejercicios -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_muscle_badge"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvCategoriaCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="@color/axf_orange"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ejercicios"
                android:textColor="@color/axf_text_tertiary"
                android:textSize="9sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Línea decorativa naranja inferior -->
    <View
        android:layout_width="50dp"
        android:layout_height="3dp"
        android:background="@color/axf_orange"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutBloqueBtn"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_bloque_btn"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Ícono círculo pequeño naranja -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_serie_num_circle"
        android:gravity="center"
        android:layout_marginEnd="14dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_nav_entreno"
            android:tint="@color/axf_orange"
            android:contentDescription="Bloque"/>
    </LinearLayout>

    <!-- Nombre del bloque + ejercicios -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBloqueNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PECHO"
            android:textColor="@color/axf_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvBloqueEjercicios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4 ejercicios"
            android:textColor="@color/axf_text_tertiary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Flecha derecha -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="@color/axf_orange"
        android:textSize="28sp"
        android:textStyle="bold"/>

</LinearLayout>